{
  "$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "files": {
    "experimentalScannerIgnores": [
      "**/dist/**",
      "**/node_modules/**",
      "apps/**/dist/**",
      "packages/**/dist/**",
      "**/routeTree.gen.ts",
      "infra/**"
    ]
  }
}
